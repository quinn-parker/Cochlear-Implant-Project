    # 3. Apply a Filter
    # --- CHOOSE YOUR FILTER HERE ---
    # To apply a low-pass filter, uncomment the next line. This keeps frequencies BELOW 2000 Hz.
    print("Applying Low-Pass Filter...")
    y_filtered = apply_low_pass_filter(y, sr, cutoff_hz=2000)
    filter_type = "lowpass"

    # To apply a high-pass filter, uncomment the next line. This keeps frequencies ABOVE 2000 Hz.
    # print("Applying High-Pass Filter...")
    # y_filtered = apply_high_pass_filter(y, sr, cutoff_hz=2000)
    # filter_type = "highpass"
    
    # 4. Analyze the Filtered Signal
    print("Analyzing filtered signal...")
