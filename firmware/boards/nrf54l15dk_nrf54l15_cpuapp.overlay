/*
 * SPDX-License-Identifier: Apache-2.0
 *
 * Device Tree Overlay for nRF54L15-DK
 * Cochlear Implant Project - PDM Microphone Configuration
 *
 * Adjust pin assignments to match your hardware setup.
 */

/ {
    chosen {
        /* Use UART for console output */
        zephyr,console = &uart20;
        zephyr,shell-uart = &uart20;
    };
};

/* UART configuration for serial output */
&uart20 {
    status = "okay";
    current-speed = <115200>;
};

/*
 * Infineon IM69D129F PDM Microphone Pin Configuration
 * 
 * Wiring to nRF54L15-DK:
 * - IM69D129F CLK  -> P1.10 (PDM clock, 1.28 MHz)
 * - IM69D129F DATA -> P1.11 (PDM data)
 * - IM69D129F VDD  -> 1.8V (supports 1.62V - 3.6V)
 * - IM69D129F GND  -> GND
 * - IM69D129F L/R  -> GND (falling edge) or VDD (rising edge)
 *
 * Note: The nrfx_pdm driver is configured in main.c
 * This overlay is for reference and any additional peripherals.
 */

/*
 * GPIO configuration for optional mic power control
 * Some MEMS mics have an enable pin
 */
/ {
    mic_control {
        compatible = "gpio-leds";
        mic_enable: mic_enable {
            /* Adjust pin as needed for your hardware */
            gpios = <&gpio1 12 GPIO_ACTIVE_HIGH>;
            label = "MIC_ENABLE";
        };
    };

    aliases {
        mic-enable = &mic_enable;
    };
};
